# LLM API Keys (at least one required for Scriptment generation)
# The backend will auto-detect and use: DeepSeek → Grok → OpenAI → Gemini

# Option 1: DeepSeek (cheapest, great for structured JSON)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Option 2: Grok (xAI — powerful, competitive pricing)
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1

# Option 3: OpenAI (GPT-4o-mini works great)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Option 4: Gemini (Google — handles both text and images)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
